<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingTop="26dp"
            android:paddingRight="16dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/demo_title"
                    android:textColor="@color/demo_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <LinearLayout
                    android:id="@+id/button_language_container"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_soul_selector"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minWidth="74dp"
                    android:orientation="horizontal"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp">

                    <ImageButton
                        android:id="@+id/button_language"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:adjustViewBounds="true"
                        android:background="@android:color/transparent"
                        android:clickable="false"
                        android:contentDescription="@string/language_switcher"
                        android:focusable="false"
                        android:padding="0dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_language_globe"
                        android:tint="@color/demo_text_secondary" />

                    <TextView
                        android:id="@+id/text_language_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/language_value_zh"
                        android:textColor="@color/demo_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/button_open_settings"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="15dp"
                    android:adjustViewBounds="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/settings"
                    android:padding="0dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_settings_gear"
                    android:tint="@color/demo_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/text_sdk_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sdk_info_label"
                    android:textColor="@color/demo_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/text_sdk_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="@string/sdk_info_placeholder"
                    android:textColor="@color/demo_text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingTop="0dp"
            android:paddingRight="16dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:baselineAligned="false"
                android:gravity="top"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_connect"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_gravity="top"
                    android:layout_weight="1"
                    android:backgroundTint="@color/demo_primary"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="@string/connect"
                    android:textColor="@color/demo_text_inverse" />

                <Button
                    android:id="@+id/button_listen"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_gravity="top"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/demo_button_disabled"
                    android:enabled="false"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="@string/start_listen"
                    android:textColor="@color/demo_text_inverse" />

                <Button
                    android:id="@+id/button_send_text"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_gravity="top"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/demo_button_disabled"
                    android:enabled="false"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="@string/send_text"
                    android:textColor="@color/demo_text_inverse" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_soul_selector_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/soul_selector_label"
                android:textColor="@color/demo_text_secondary"
                android:textSize="12sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp">

                <androidx.appcompat.widget.AppCompatSpinner
                    android:id="@+id/spinner_soul_selector"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soul_selector"
                    android:dropDownWidth="match_parent"
                    android:paddingLeft="12dp"
                    android:paddingRight="40dp"
                    android:spinnerMode="dropdown" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="12dp"
                    android:clickable="false"
                    android:contentDescription="@null"
                    android:focusable="false"
                    android:src="@drawable/ic_spinner_arrow"
                    android:tint="@color/demo_text_secondary" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/text_logs_panel_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/logs_panel"
                    android:textColor="@color/demo_text_primary" />

                <ImageButton
                    android:id="@+id/button_clear_logs"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/clear_logs"
                    android:padding="4dp"
                    android:src="@drawable/ic_clear_logs"
                    android:tint="@color/demo_text_secondary" />
            </LinearLayout>

            <ScrollView
                android:id="@+id/scroll_logs"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:background="@color/demo_panel_bg"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/text_logs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="160dp"
                    android:padding="12dp"
                    android:text="@string/logs_empty"
                    android:textColor="@color/demo_text_primary"
                    android:textSize="13sp"
                    android:textIsSelectable="true"
                    android:typeface="monospace" />
            </ScrollView>
        </LinearLayout>
    </LinearLayout>

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/view_expression_animation"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:visibility="gone" />
</FrameLayout>
